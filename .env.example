# ============================================================
# AI Job Discovery System — Environment Configuration Template
# Copy this to .env and fill in your real values
# ============================================================

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# Apify (https://apify.com)
APIFY_API_TOKEN=apify_api_...

# LinkedIn credentials (used for Easy Apply automation)
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=yourpassword

# Google Sheets (the spreadsheet ID from the URL)
GOOGLE_SHEETS_SPREADSHEET_ID=your_sheet_id_here

# Application Settings
MAX_APPLICATIONS_PER_DAY=15
MIN_SCORE_THRESHOLD=70
SALARY_TARGET_MIN=165000
PREFERRED_REMOTE=true
