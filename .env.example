# ============================================================
# AI Job Discovery System — Environment Configuration Template
# Copy this to .env and fill in your real values
# ============================================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Apify (https://apify.com)
APIFY_API_TOKEN=apify_api_...

# LinkedIn credentials (used for Easy Apply automation)
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=yourpassword
# LinkedIn li_at cookie (used for connection finder — get from browser DevTools > Cookies)
LINKEDIN_LI_AT=your_li_at_cookie_here

# Google Sheets (the spreadsheet ID from the URL)
GOOGLE_SHEETS_SPREADSHEET_ID=your_sheet_id_here

# Application Settings
MAX_APPLICATIONS_PER_DAY=15
MIN_SCORE_THRESHOLD=70
SALARY_TARGET_MIN=165000
PREFERRED_REMOTE=true

# Telegram Notifications (for new-job alerts)
# 1. Message @BotFather on Telegram, send /newbot, follow prompts to get token
# 2. Message your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat ID
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_IDS=123456789,987654321
# Admin gets interactive controls (form Q&A); Viewer gets notification-only
TELEGRAM_ADMIN_CHAT_IDS=123456789
TELEGRAM_VIEWER_CHAT_IDS=987654321

# Multi-Platform Search (comma-separated)
# Available: linkedin,indeed,glassdoor,dice,ziprecruiter,simplyhired,monster,builtin
SEARCH_PLATFORMS=linkedin,indeed,glassdoor,dice,ziprecruiter,simplyhired,monster,builtin

# Firecrawl (web scraping for Dice, ZipRecruiter, SimplyHired, Monster, Built In)
FIRECRAWL_API_KEY=fc-your-api-key-here

# Follow-Up Tracker (days before sending a reminder)
FOLLOW_UP_DAYS=7

# Daily Report (set to false to disable)
DAILY_REPORT_ENABLED=true

# Screenshot cleanup: delete .tmp/screenshots older than N days (default 7). Set 0 to disable.
SCREENSHOT_RETENTION_DAYS=7

# Telegram /shell command: set a PIN to allow running shell commands from the bot (leave unset to disable)
# SHELL_PIN=your-secret-pin

# ATS Portal Credentials (used for Workday, Greenhouse, etc. account creation/login)
ATS_EMAIL=your@email.com
ATS_PASSWORD=your-ats-password
# Gmail email verification uses OAuth2 via credentials.json (same as Sheets).
# First run will open a browser for consent. Token saved to token_gmail.json.

# Ollama (free local LLM fallback for scoring and resume/cover letter generation)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_WRITING_MODEL=qwen3:4b
# Use Ollama to intelligently fill external ATS application forms (default: true)
OLLAMA_FORM_FILL=true

# Dashboard
DASHBOARD_SECRET_KEY=change-me-to-a-random-secret
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme123

# NotebookLM MCP (core features use browser auth — no key needed)
# Gemini API adds deep_research, gemini_query, document upload
GEMINI_API_KEY=your-gemini-api-key-from-aistudio.google.com
GEMINI_DEEP_RESEARCH_ENABLED=true
GEMINI_DEFAULT_MODEL=gemini-3-flash-preview

# Manus AI - Deep Research Agent (https://manus.im)
MANUS_API_KEY=your-manus-api-key-here
