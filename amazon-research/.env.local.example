# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Firebase Client (public — safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server-only — NEVER expose to client)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Amazon SP-API (server-only — NEVER expose to client)
# Set to "true" to enable live data from Amazon SP-API
AMAZON_SP_API_ENABLED=false
# Your Amazon Seller ID (Merchant Token from Seller Central)
AMAZON_SELLER_ID=
# Marketplace ID (defaults to US: ATVPDKIKX0DER)
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
# Region: na, eu, or fe (defaults to na)
AMAZON_MARKETPLACE_REGION=na
# SP-API OAuth credentials (from Seller Central Developer apps)
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_SP_API_REFRESH_TOKEN=

# Cron job authentication (generate a random secret)
CRON_SECRET=
