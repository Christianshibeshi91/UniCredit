# UniCredit Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Server ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# ─── Security (REQUIRED) ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-secret-change-in-production

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5000

# ─── Firebase (REQUIRED in production) ──────────────────────────────────────────
# Paste the full JSON of your Firebase service account key (single line)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Redis (REQUIRED in production) ─────────────────────────────────────────────
# Format: redis://user:password@host:6379
REDIS_URL=

# ─── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRODUCT_ID=

# ─── SendGrid ───────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@unicredit.app
SENDGRID_FROM_NAME=UniCredit

# ─── Google Cloud Storage ────────────────────────────────────────────────────────
GCS_BUCKET=
GCS_PROJECT_ID=

# ─── Google OAuth ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── Logging ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Monitoring ──────────────────────────────────────────────────────────────────
SENTRY_DSN=
